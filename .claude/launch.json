{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev"],
      "port": 3000,
      "cwd": "frontend"
    },
    {
      "name": "FastAPI Backend (uvicorn)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["server:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "backend"
    }
  ]
}
